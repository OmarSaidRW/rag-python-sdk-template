# ──────────────────────────────────────────────
# Azure Blob Storage
# ──────────────────────────────────────────────
CONNECTION_STRING=your_azure_storage_connection_string_here
BLOB_CONTAINER_NAME=your_container_name

# ──────────────────────────────────────────────
# Qdrant Vector Database
# ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# ──────────────────────────────────────────────
# Azure OpenAI — Embeddings
# ──────────────────────────────────────────────
EMBEDDINGS_MODEL_NAME=text-embedding-ada-002
EMBEDDINGS_MODEL_ENDPOINT=https://your-resource.openai.azure.com/
EMBEDDINGS_MODEL_API_KEY=your_azure_openai_api_key
EMBEDDINGS_API_VERSION=2023-05-15

# ──────────────────────────────────────────────
# Azure OpenAI — Chat / Completion (RAG agent)
# ──────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4

# ──────────────────────────────────────────────
# Database (PocketBase or other)
# ──────────────────────────────────────────────
DATABASE_URL=http://localhost:8090

# ──────────────────────────────────────────────
# Testing (optional overrides)
# ──────────────────────────────────────────────
TEST_BLOB_CONTAINER_NAME=test-container
